# =============================================================================
# Verdecora AI Agents — Environment Variables
# Copy to .env and fill in values for local development
# =============================================================================

# --- Azure Identity (DefaultAzureCredential works with az login) ---
# AZURE_TENANT_ID=562029ef-9022-45a6-b255-40cd71ebb2ce
# AZURE_CLIENT_ID=        # Only needed for service principal auth
# AZURE_CLIENT_SECRET=    # Only needed for service principal auth

# --- AI Foundry / Azure AI Services ---
AZURE_AI_ENDPOINT=https://verdecora-ais-dev.cognitiveservices.azure.com/
AI_MODEL_PRIMARY=gpt-5
AI_MODEL_SECONDARY=gpt-5-mini

# --- Document Intelligence ---
DOCINTELL_ENDPOINT=https://verdecora-docintell-dev.cognitiveservices.azure.com/

# --- Cosmos DB ---
COSMOS_ENDPOINT=https://cosmos-albaranes-dev.documents.azure.com:443/
COSMOS_DATABASE=albaranes-db

# --- Service Bus ---
SERVICEBUS_NAMESPACE=sb-albaranes-dev.servicebus.windows.net
SERVICEBUS_QUEUE_INGESTION=extraccion-queue
SERVICEBUS_EXTRACTION_QUEUE=extraccion-queue
EXTRACTION_QUEUE_NAME=extraccion-in
FLOW0_SOURCE_QUEUE_NAME=extraccion-queue
FLOW0_TARGET_QUEUE_NAME=extraccion-in
SERVICEBUS_QUEUE_DLQ=albaran-dlq
HITL_QUEUE_NAME=hitl-review

# --- Storage Account ---
STORAGE_ACCOUNT_NAME=stalbaranesdev
STORAGE_CONTAINER_RAW=raw-albaranes
STORAGE_CONTAINER_PROCESSED=processed-albaranes
STORAGE_CONTAINER_QUARANTINE=quarantine

# --- Azure Communication Services (Email) ---
ACS_ENDPOINT=https://verdecora-acs-dev.unitedstates.communication.azure.com
ACS_SENDER=DoNotReply@<your-verified-domain>
HITL_NOTIFY_EMAIL=admin@gpsazure.com

# --- Key Vault ---
KEYVAULT_URL=https://kv-albaranes-dev.vault.azure.net/

# --- Azure Container Registry ---
ACR_NAME=acralbaranesdev
ACR_LOGIN_SERVER=acralbaranesdev.azurecr.io

# --- Upload Web ---
UPLOAD_WEB_PORT=8000
SESSION_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=https://upload-web-d3hpbffsfwercgcv.b02.azurefd.net

# --- Business Central MCP ---
BC_MCP_URL=https://mcp.businesscentral.dynamics.com
BC_TENANT_ID=562029ef-9022-45a6-b255-40cd71ebb2ce
BC_ENVIRONMENT=Production
BC_COMPANY=CRONUS USA, Inc.
BC_CONFIG_NAME=DefaultMCPKiko

# --- Feature Flags ---
FEATURE_FLAG_SKIP_TRIAGE=false
FEATURE_FLAG_SKIP_COHERENCE=false
FEATURE_FLAG_DRY_RUN=true

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_SERVICE_NAME=verdecora-agents
LOG_LEVEL=INFO
